**/macos/Flutter/ephemeral/
**/linux/flutter/ephemeral/
**/windows/flutter/ephemeral/

# Dart generated
*.g.dart
*.freezed.dart

# Local secrets / signing files (keep out of Git)
**/key.properties
**/*.jks
**/*.keystore
**/*.p12
**/*.p8
**/*.pem
**/*serviceAccount*.json
**/*credentials*.json

# Environment files
.env
.env.*
*.env

# Local Firebase config for this app
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart
